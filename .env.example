# ===== Supabase =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ===== Server =====
PORT=3001

# CORS — comma-separated list of allowed frontend origins. When unset, defaults
# to localhost dev ports (5173, 5174, 5175, 3000). Set this in prod to your
# Vercel URL (e.g. ALLOWED_ORIGINS=https://padee.ai,https://www.padee.ai).
# Without this, the prod frontend is rejected by CORS.
ALLOWED_ORIGINS=

# ===== Admin =====
ADMIN_PASSWORD=change-me-before-deploy

# ===== LLM routing (Phase 1) =====
# IMPORTANT: model defaults below reflect what's currently running. Older
# models (llama-3.1-70b-versatile, llama-3.2-11b-vision-preview, llama-3.1-
# 8b-instant) were DEPRECATED — see CLAUDE.md "Critical model + API key
# facts" for the current names.
LLM_DOUBT_SIMPLE=groq/llama-3.3-70b-versatile
LLM_DOUBT_VISION=groq/meta-llama/llama-4-scout-17b-16e-instruct
LLM_PRACTICE_GEN=groq/llama-3.3-70b-versatile
LLM_WORKSHEET=gpt-4o-mini
LLM_VISUAL_EXPLAIN=gpt-4o
LLM_VALIDATION=groq/llama-3.3-70b-versatile
LLM_FALLBACK=gpt-4o-mini
# Pa's debrief on the test results screen — quality > speed. ~150 words of
# diagnosis + analogy. Defaults to gpt-4o-mini (₹~0.05 per debrief). Llama
# 3.3-70b also works but produces flatter prose.
LLM_TEST_INSIGHTS=gpt-4o-mini
# Concept extraction from uploaded NCERT chapters (admin panel). gpt-4o
# gives best-quality concept boundaries; ~₹0.15 per chapter. Mini works
# but tends to over-split.
LLM_CONCEPT_EXTRACT=gpt-4o
# Hero recommendation copy (1-2 sentence "fix this concept now" prose).
# Per-student per-day; ~₹0.002/student. Falls back to a template if unset.
LLM_RECOMMENDATION=gpt-4o-mini
# Vision-doubt fallback when Groq's vision model errors before any chunk
# is delivered. gpt-4o supports image_url payloads natively.
LLM_VISION_FALLBACK=gpt-4o

# Legacy / unused — kept only because admins may have these in their .env
# from earlier deploys. Safe to delete:
#   LLM_EVALUATION=gpt-4o-mini      (the /evaluate endpoint is a 501 stub)
#   LLM_HOME_CURATOR=...            (no current code path)

# ===== Embeddings =====
EMBEDDING_MODEL=text-embedding-3-small

# ===== API keys (add as needed) =====
GROQ_API_KEY=
OPENAI_API_KEY=

# ===== Text-to-Speech (Google Cloud, optional) =====
# When set, /api/ai/tts proxies to Google TTS with en-IN voices and in-memory
# LRU cache. When unset, the frontend falls back to the browser's Web Speech
# API (free, robotic-ish). Enable via https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
GOOGLE_TTS_API_KEY=
# Voice — defaults to en-IN-Wavenet-D (warm, Indian English female).
# Other options: en-IN-Wavenet-A|B|C (varied), en-IN-Neural2-A|B|C|D (premium quality),
# en-IN-Standard-A|B|C|D (cheapest). Full list: https://cloud.google.com/text-to-speech/docs/voices
LLM_TTS_VOICE=en-IN-Wavenet-D
